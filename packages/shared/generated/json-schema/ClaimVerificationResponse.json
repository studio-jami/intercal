{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "ClaimVerificationResponse.json",
    "type": "object",
    "properties": {
        "claimText": {
            "type": "string"
        },
        "verdict": {
            "$ref": "VerificationVerdict.json"
        },
        "confidence": {
            "$ref": "Confidence.json"
        },
        "supportingEvidence": {
            "type": "array",
            "items": {
                "$ref": "Citation.json"
            }
        },
        "contradictingEvidence": {
            "type": "array",
            "items": {
                "$ref": "Citation.json"
            }
        },
        "asOf": {
            "type": "string",
            "format": "date-time"
        }
    },
    "required": [
        "claimText",
        "verdict",
        "confidence",
        "supportingEvidence",
        "contradictingEvidence"
    ]
}