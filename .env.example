# Intercal environment template. Copy to `.env` for local development.
# NEVER commit a real `.env`. Secrets live in the host's secret store in deployed envs.
# Every value here selects or configures an ADAPTER — no provider is hard-wired.

# ---- Core datastore (Postgres + pgvector) -------------------------------------
# Local docker-compose default. Swap the URL for Neon / Supabase / a VPS with no code change.
DATABASE_URL=postgres://intercal:intercal@localhost:5432/intercal
# Pilot example (Neon): postgres://USER:PASSWORD@ep-xxxx.neon.tech/intercal?sslmode=require
# Direct (unpooled) connection for migrations / long jobs (Neon provides a separate host).
# DATABASE_URL_UNPOOLED=

# ---- Object storage (S3-compatible adapter) -----------------------------------
# Local default = MinIO. Pilot = Cloudflare R2 (S3 API). Prod = any S3-compatible store.
STORAGE_PROVIDER=s3
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=intercal
S3_ACCESS_KEY_ID=intercal
S3_SECRET_ACCESS_KEY=intercal-secret
S3_FORCE_PATH_STYLE=true

# ---- Queue / cache (adapter) --------------------------------------------------
# Local default = Redis/Valkey. Pilot = Upstash (REST or redis://). Fallback = postgres (pgmq).
QUEUE_PROVIDER=redis
REDIS_URL=redis://localhost:6379
# Upstash REST adapter path (pilot). NEVER commit real values.
# Also backs the REST rate-limit store: when BOTH are set, the API uses Upstash (one shared counter
# across instances); otherwise it falls back to an in-process limiter. See
# docs/operations/auth-and-rate-limits.md.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ---- Embeddings (adapter) -----------------------------------------------------
# Default = local ONNX (fastembed), zero-cost. Optional hosted providers behind the same port.
EMBEDDINGS_PROVIDER=local
EMBEDDINGS_MODEL=BAAI/bge-small-en-v1.5
EMBEDDINGS_DIM=384
# Hosted example: EMBEDDINGS_PROVIDER=openai  OPENAI_API_KEY=...

# ---- LLM extraction / synthesis (adapter) -------------------------------------
# Primary = vertex (Vertex AI via ADC / SA key). Fallback = gemini (API key, postpay).
# Groq / Anthropic / OpenAI are also behind the same port.
LLM_PROVIDER=vertex
LLM_MODEL=gemini-2.5-flash
# Vertex AI (primary). Requires ADC: set GOOGLE_APPLICATION_CREDENTIALS to a SA JSON key.
# LLM_PROVIDER=vertex is the default when VERTEX_PROJECT is set; see docs/operations/resource-budget.md.
# VERTEX_PROJECT falls back to GCLOUD_PROJECT_ID if unset; GOOGLE_APPLICATION_CREDENTIALS
# falls back to GOOGLE_SERVICE_ACCOUNT_KEY (path), so a single SA-key .env drives Vertex.
VERTEX_PROJECT=
VERTEX_LOCATION=us-east4
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
# GCLOUD_PROJECT_ID=
# GOOGLE_SERVICE_ACCOUNT_KEY=/path/to/service-account-key.json
# Gemini API key (fallback, postpay daily limit).
# GEMINI_API_KEY=
# GROQ_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ---- Ingestion throttle knobs (resource-budget.md) ---------------------------
# Cron expression informational; GitHub Actions reads this directly in the workflow.
INGEST_CRON=0 */6 * * *
# Hard cap on documents per scheduled ingestion run; override per-run with --max-documents.
INGEST_MAX_DOCS_PER_RUN=200
# Optional: GitHub PAT for the github_releases_v1 source adapter. Raises the REST
# rate limit from 60/hr (unauthenticated) to 5,000/hr. Public-repo read scope is
# enough; leave unset for low-cadence public ingestion. NEVER commit a real token.
# GITHUB_TOKEN=
# Skip LLM extraction for documents whose content_hash has not changed.
EXTRACT_ONLY_CHANGED=true
# Hard daily cap on LLM API calls across all providers.
LLM_DAILY_REQUEST_BUDGET=2000
# Per-call output token cap forwarded to LLM adapters.
LLM_MAX_OUTPUT_TOKENS=2048
# Per-call LLM request timeout in seconds (transient failures retry within the port).
LLM_TIMEOUT_SECONDS=60
# Primary LLM provider name (vertex -> gemini fallback order). Informational — used by
# resource-budget monitoring; actual routing is via LLM_PROVIDER above.
LLM_PRIMARY=vertex
# Local fastembed batch size (free, CPU only).
EMBEDDINGS_BATCH_SIZE=64

# ---- Scheduler (adapter) ------------------------------------------------------
# Local = inline/cron. Pilot = GitHub Actions / Modal invoke the same worker entrypoints.
SCHEDULER_PROVIDER=local

# ---- API / MCP server ---------------------------------------------------------
API_PORT=8787
MCP_PORT=8788
# Public base URL of the deployed API (used by SDK/dashboard). Deploy-target agnostic.
PUBLIC_API_BASE_URL=http://localhost:8787

# ---- Observability (adapter; optional) ----------------------------------------
LOG_LEVEL=info
# SENTRY_DSN=

# ---- Secret fan-out: operator / automation lane -------------------------------
# These authenticate the fan-out + deploy tooling (scripts/ops/) to each platform.
# They are NOT app-runtime secrets and are NEVER fanned into the app env
# (see docs/operations/secrets.md and scripts/ops/secrets.manifest.json). NEVER commit values.
#
# Vercel (app + REST + MCP on one domain): VERCEL_TOKEN authenticates the env push.
# VERCEL_TOKEN=
# VERCEL_PROJECT_ID=
# VERCEL_TEAM_ID=
# VERCEL_TEAM_SLUG=
# VERCEL_USER_ID=
# VERCEL_DOMAIN=
#
# GitHub Actions secret push: `gh` CLI keyring auth is used; GITHUB_REPO is owner/repo (or URL).
# GITHUB_TOKEN (optional) overrides gh auth; it is the source-adapter read token, not a payload.
# GITHUB_REPO=owner/repo
#
# GCloud / Cloud Run (Plan 07 W4): SA JSON used by CI; CLOUD_RUN_SERVICE names the service once it exists.
# GCLOUD_PROJECT_ID=
# GCLOUD_REGION=
# GCP_SA_KEY=
# CLOUD_RUN_SERVICE=
#
# Neon control-plane (branching / backups; operator-only — runtime uses DATABASE_URL).
# NEON_API_KEY=
# NEON_PROJECT_ID=
# NEON_AUTH_URL=
# NEON_AUTH_JWKS_URL=
# NEON_DATA_API_URL=
#
# Cloudflare control-plane (R2 bucket admin; operator-only — runtime uses S3_* keys).
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
