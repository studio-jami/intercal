{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "FeedbackRequest.json",
    "type": "object",
    "properties": {
        "targetType": {
            "$ref": "FeedbackTargetType.json"
        },
        "targetId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
        },
        "concernType": {
            "$ref": "FeedbackConcernType.json"
        },
        "summary": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
        },
        "details": {
            "type": "string",
            "maxLength": 4000
        }
    },
    "required": [
        "targetType",
        "targetId",
        "concernType",
        "summary"
    ],
    "description": "Bounded public feedback that creates a review record without mutating canonical knowledge."
}