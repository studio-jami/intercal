{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "EntityQuery.json",
    "type": "object",
    "properties": {
        "name_or_id": {
            "type": "string"
        },
        "at_date": {
            "type": "string",
            "format": "date-time",
            "description": "Point-in-time read: entity state as of this date."
        },
        "token_budget": {
            "type": "integer",
            "minimum": -2147483648,
            "maximum": 2147483647
        }
    },
    "required": [
        "name_or_id"
    ]
}