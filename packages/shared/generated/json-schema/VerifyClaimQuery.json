{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "VerifyClaimQuery.json",
    "type": "object",
    "properties": {
        "claim_text": {
            "type": "string"
        },
        "as_of_date": {
            "type": "string",
            "format": "date-time"
        },
        "token_budget": {
            "type": "integer",
            "minimum": -2147483648,
            "maximum": 2147483647
        }
    },
    "required": [
        "claim_text"
    ]
}