{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://intercal.dev/schemas/secrets.manifest.json",
  "title": "Intercal secrets fan-out manifest",
  "description": "Registry of secret/config NAMES and target mapping. NAMES + TARGETS + METADATA ONLY — never values.",
  "type": "object",
  "required": ["secrets"],
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "description": { "type": "string" },
    "targets": { "type": "object" },
    "vercelTargets": {
      "type": "array",
      "items": { "type": "string", "enum": ["production", "preview", "development"] }
    },
    "secrets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "lane", "targets"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
          "lane": { "type": "string", "enum": ["app-runtime", "operator"] },
          "targets": {
            "type": "array",
            "items": { "type": "string", "enum": ["vercel", "github", "cloudrun"] }
          },
          "optional": { "type": "boolean" },
          "note": { "type": "string" }
        }
      }
    }
  }
}
