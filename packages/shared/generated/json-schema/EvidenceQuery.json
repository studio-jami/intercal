{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "EvidenceQuery.json",
    "type": "object",
    "properties": {
        "query": {
            "type": "string"
        },
        "from_date": {
            "type": "string",
            "format": "date-time"
        },
        "to_date": {
            "type": "string",
            "format": "date-time"
        },
        "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100
        }
    },
    "required": [
        "query"
    ]
}