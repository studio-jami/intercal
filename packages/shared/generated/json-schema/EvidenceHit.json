{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "EvidenceHit.json",
    "type": "object",
    "properties": {
        "documentId": {
            "type": "string"
        },
        "snippet": {
            "type": "string"
        },
        "score": {
            "type": "number",
            "minimum": 0
        },
        "citation": {
            "$ref": "Citation.json"
        }
    },
    "required": [
        "documentId",
        "snippet",
        "score",
        "citation"
    ]
}