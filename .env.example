# Intercal environment template. Copy to `.env` for local development.
# NEVER commit a real `.env`. Secrets live in the host's secret store in deployed envs.
# Every value here selects or configures an ADAPTER — no provider is hard-wired.

# ---- Core datastore (Postgres + pgvector) -------------------------------------
# Local docker-compose default. Swap the URL for Neon / Supabase / a VPS with no code change.
DATABASE_URL=postgres://intercal:intercal@localhost:5432/intercal
# Pilot example (Neon): postgres://USER:PASSWORD@ep-xxxx.neon.tech/intercal?sslmode=require

# ---- Object storage (S3-compatible adapter) -----------------------------------
# Local default = MinIO. Pilot = Cloudflare R2 (S3 API). Prod = any S3-compatible store.
STORAGE_PROVIDER=s3
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=intercal
S3_ACCESS_KEY_ID=intercal
S3_SECRET_ACCESS_KEY=intercal-secret
S3_FORCE_PATH_STYLE=true

# ---- Queue / cache (adapter) --------------------------------------------------
# Local default = Redis/Valkey. Pilot = Upstash (REST or redis://). Fallback = postgres (pgmq).
QUEUE_PROVIDER=redis
REDIS_URL=redis://localhost:6379

# ---- Embeddings (adapter) -----------------------------------------------------
# Default = local ONNX (fastembed), zero-cost. Optional hosted providers behind the same port.
EMBEDDINGS_PROVIDER=local
EMBEDDINGS_MODEL=BAAI/bge-small-en-v1.5
EMBEDDINGS_DIM=384
# Hosted example: EMBEDDINGS_PROVIDER=openai  OPENAI_API_KEY=...

# ---- LLM extraction / synthesis (adapter) -------------------------------------
# Default = a free tier (Gemini / Groq). Paid providers are fallbacks behind the same port.
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
# GEMINI_API_KEY=
# GROQ_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ---- Ingestion throttle knobs (resource-budget.md) ---------------------------
# Cron expression informational; GitHub Actions reads this directly in the workflow.
INGEST_CRON=0 */6 * * *
# Hard cap on documents per scheduled ingestion run; override per-run with --max-documents.
INGEST_MAX_DOCS_PER_RUN=200
# Skip LLM extraction for documents whose content_hash has not changed.
EXTRACT_ONLY_CHANGED=true
# Hard daily cap on LLM API calls across all providers.
LLM_DAILY_REQUEST_BUDGET=2000
# Per-call output token cap forwarded to LLM adapters.
LLM_MAX_OUTPUT_TOKENS=2048
# Primary LLM provider (vertex -> gemini fallback).
LLM_PRIMARY=vertex
# Local fastembed batch size (free, CPU only).
EMBEDDINGS_BATCH_SIZE=64

# ---- Scheduler (adapter) ------------------------------------------------------
# Local = inline/cron. Pilot = GitHub Actions / Modal invoke the same worker entrypoints.
SCHEDULER_PROVIDER=local

# ---- API / MCP server ---------------------------------------------------------
API_PORT=8787
MCP_PORT=8788
# Public base URL of the deployed API (used by SDK/dashboard). Deploy-target agnostic.
PUBLIC_API_BASE_URL=http://localhost:8787

# ---- Observability (adapter; optional) ----------------------------------------
LOG_LEVEL=info
# SENTRY_DSN=
